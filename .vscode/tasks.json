{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar projeto",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "main.c",
                "matriz.c",
                "-o",
                "output/matriz.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Compilar e Executar",
            "type": "shell",
            "command": "gcc main.c matriz.c -o output/matriz.exe && .\\output\\matriz.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            }
        }
    ]
}